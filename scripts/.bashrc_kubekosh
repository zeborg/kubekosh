#!/usr/bin/env bash
# KubeKosh safe shell profile — inclusive allowlist security
#
# Uses extdebug + trap DEBUG so that ONLY whitelisted first-words execute.
# Aliases are expanded BEFORE the trap fires, so:
#   - Predefined aliases (k, kg, klogs) → expand to kubectl → allowed
#   - User-created safe aliases (alias myk='kubectl get nodes') → allowed
#   - User-created malicious aliases (alias boom='rm -rf /') → expanded to rm → blocked

# ── Allowlist of allowed command names ──────────────────────────────
KUBEKOSH_ALLOWED="\
  kubectl cat head tail grep egrep fgrep awk sed wc tr cut sort uniq column jq paste tee \
  ls touch mkdir cp mv find which whereis file stat \
  cd pwd pushd popd dirs \
  echo printf export set unset env printenv alias unalias type hash source history clear \
  date sleep true false test \
  nano vi vim \
  curl wget nslookup dig ping nc \
  ps top jobs bg fg wait kill \
  base64 openssl xargs \
  k3s crictl ctr helm kustomize"

# ── Environment ─────────────────────────────────────────────────────
export KUBECONFIG=/root/.kube/config

# ── Predefined kubectl aliases ──────────────────────────────────────
alias k='kubectl'
alias kg='kubectl get'
alias kgp='kubectl get pods'
alias kga='kubectl get pods --all-namespaces'
alias kgd='kubectl get deployments'
alias kgs='kubectl get services'
alias kgn='kubectl get nodes'
alias kgns='kubectl get namespaces'
alias kd='kubectl describe'
alias kdp='kubectl describe pod'
alias kex='kubectl exec -it'
alias klogs='kubectl logs'
alias kaf='kubectl apply -f'
alias kdf='kubectl delete -f'
alias krm='kubectl delete'

# ── Useful functions ────────────────────────────────────────────────
kns() { kubectl config set-context --current --namespace="$1"; }
kctx() { kubectl config use-context "$1"; }

# ── Completion ──────────────────────────────────────────────────────
source <(kubectl completion bash) 2>/dev/null || true
complete -F __start_kubectl k 2>/dev/null || true

# ── Prompt & welcome ────────────────────────────────────────────────
PS1='\[\033[01;32m\]\u@k8s-lab\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '

echo ""
echo "  ⎈ KubeKosh - Node: k8s-lab"
KUBECTL_VER=$(kubectl version --client 2>/dev/null | grep -oE 'v[0-9]+\.[0-9]+\.[0-9]+[^ ]*' | head -1)
echo "    kubectl ${KUBECTL_VER}"
echo "    Aliases: k=kubectl, kgp=get pods, kaf=apply -f, kns=set-namespace, kgns=get namespaces, kex=kubectl exec -it"
echo "             kgd=get deployments, kgn=get nodes, kgs=get services, kdp=describe pod, krm=kubectl delete, klogs=kubectl logs"
echo ""

# ── Command allowlist trap (MUST be last — fires on every subsequent command) ──
shopt -s extdebug 2>/dev/null

_kubekosh_check() {
  local cmd="$BASH_COMMAND"
  local first
  first="${cmd#"${cmd%%[![:space:]]*}"}"
  first="${first%% *}"

  local a
  for a in $KUBEKOSH_ALLOWED; do
    [[ "$first" == "$a" ]] && return 0
  done

  if [[ "$(type -t "$first" 2>/dev/null)" == "alias" ]]; then
    local expansion
    expansion=$(alias "$first" 2>/dev/null | sed "s/^alias [^=]*='//;s/'$//")
    local exp_first="${expansion%% *}"
    for a in $KUBEKOSH_ALLOWED; do
      [[ "$exp_first" == "$a" ]] && return 0
    done
    printf '\x1b[31m Blocked: alias '\''%s'\'' expands to '\''%s'\'' (not allowed)\x1b[0m\n' "$first" "$exp_first" >&2
    return 1
  fi

  printf '\x1b[31m Blocked: '\''%s'\'' is not allowed in this environment\x1b[0m\n' "$first" >&2
  return 1
}

trap '_kubekosh_check' DEBUG
